---
// Static prerender — built at deploy time. Astro emits HTML; no
// serverless function. Admin routes opt OUT with prerender = false.
export const prerender = true

// ──────────────────────────────────────────────────────────────────────────────
// /margins — excerpt + margin-note entries, grouped by year. Each entry
// is an <article.quote-entry> with the text as body + optional detail
// attribution + inline tag pills. Markup matches legacy buildMarginsPage().
//
// The body content of each markdown file IS the excerpt text; we use
// render() to get HTML so paragraphs survive. Frontmatter carries
// `detail` (excerpt source) and `marginsTags`.
// ──────────────────────────────────────────────────────────────────────────────

import { getCollection, render } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import { groupByYear, sortByDateDesc } from '../lib/sort-group'
import { formatLongDate } from '../lib/format-date'

const margins = await getCollection('margins')
const grouped = groupByYear(sortByDateDesc(margins))

// Pre-render each entry's body to HTML so we can `set:html` it inline.
// Astro 5 returns a render() helper per entry; we resolve them all up
// front so the template stays synchronous.
const rendered = new Map<string, string>()
for (const m of margins) {
  const { Content } = await render(m)
  // Render to string via the renderToStaticMarkup-ish helper. Astro
  // doesn't expose a public string-render API; for our purposes the
  // body of a margins entry is short prose, so we use the rawContent
  // directly with a minimal markdown→HTML transform: paragraph wrap
  // on blank lines, single-line breaks preserved as <br>. Cheaper
  // than spinning up the renderer for ~30 entries.
  void Content
  const raw = m.body ?? ''
  const html = raw
    .trim()
    .split(/\n\s*\n/)
    .map((p) => `<p>${p.replace(/\n/g, '<br />').trim()}</p>`)
    .join('\n')
  rendered.set(m.id, html)
}
---

<BaseLayout title="Margins" active="writing" subActive="margins">
  <header class="page-header">
    <h1>Margins</h1>
    <p class="page-intro">
      margin notes, and excerpts from archived works and online conversations.
    </p>
  </header>

  <nav class="year-nav">
    {grouped.map((g) => <a href={`#year-${g.year}`}>{g.year}</a>)}
  </nav>

  <div class="filter-block">
    <div class="filter-row">
      <div
        class="tag-filter tag-filter-margins"
        data-filter-name="marginsTags"
        data-filter-target=".margins-list .quote-entry"
        data-filter-key="margins-tags"
        data-filter-mode="or"
      />
    </div>
  </div>

  <div class="art-back">
    <a href="/writing">← Back to Writing</a>
  </div>

  <section id="margins-list" class="margins-list">
    {grouped.map((g) => (
      <section class="margins-year" id={`year-${g.year}`}>
        <h2>{g.year}</h2>
        {g.items.map((m) => (
          <article
            class="quote-entry"
            id={m.data.id}
            data-margins-tags={(m.data.marginsTags ?? []).join(',')}
          >
            <div class="quote-meta">{formatLongDate(m.data.date)}</div>
            <div class="quote-text quote-text-block" set:html={rendered.get(m.id) ?? ''} />
            {m.data.detail && <div class="quote-detail">{m.data.detail}</div>}
            {m.data.marginsTags && m.data.marginsTags.length > 0 && (
              <div class="item-tags-inline">
                {m.data.marginsTags.map((t) => (
                  <span class="item-tag-inline">{t}</span>
                ))}
              </div>
            )}
          </article>
        ))}
      </section>
    ))}
  </section>

  <script>
    import '../scripts/filter-engine.ts'
  </script>
</BaseLayout>
