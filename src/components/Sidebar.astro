---
// ──────────────────────────────────────────────────────────────────────────────
// Sidebar — single nav definition, replaces the 18 copy-pasted sidebars in
// the legacy site. Pass `active` to highlight the current top-level link.
//
//   <Sidebar active="archive" />
//
// `subActive` highlights a sub-nav link (e.g. "altered-states" under Writing).
// ──────────────────────────────────────────────────────────────────────────────

interface Props {
  active?:
    | 'home'
    | 'archive'
    | 'art'
    | 'writing'
    | 'now'
    | 'questions'
    | 'bio'
  subActive?:
    // Art sub-nav
    | 'exhibits'
    | 'photo'
    // Writing sub-nav
    | 'altered-states'
    | 'margins'
    | 'quotes'
}

const { active, subActive } = Astro.props

// Helper to flag the active class without polluting template-side logic.
const cls = (key: NonNullable<Props['active']>) =>
  active === key ? 'active' : undefined
const subCls = (key: NonNullable<Props['subActive']>) =>
  subActive === key ? 'nav-sub active' : 'nav-sub'
---

<nav class="sidebar">
  <h1>Christopher Shenefelt</h1>

  <a href="/" class={cls('home')}>Home</a>
  <a href="/archive" class={cls('archive')}>Archive</a>

  <a href="/art" class={cls('art')}>Artwork</a>
  {active === 'art' && (
    <>
      <a href="/exhibits" class={subCls('exhibits')}>Exhibits</a>
      <a href="/photography" class={subCls('photo')}>Photography</a>
    </>
  )}

  <a href="/writing" class={cls('writing')}>Writing</a>
  {active === 'writing' && (
    <>
      <a href="/altered-states" class={subCls('altered-states')}>Altered States</a>
      <a href="/margins" class={subCls('margins')}>Margins &amp; Excerpts</a>
      <a href="/quotes" class={subCls('quotes')}>Quotes from Others</a>
    </>
  )}

  <a href="/now" class={cls('now')}>Now</a>
  <a href="/questions" class={cls('questions')}>Questions</a>
  <a href="/bio" class={cls('bio')}>Biography</a>

  {/* External links (Harmonic Theism, Dao De Zion, Instagram, X) all
      live in the footer now — duplicating them in the sidebar muddied
      the navigation. Sidebar is purely first-party site sections. */}

  {/* Pinned to the absolute bottom of the sidebar column via the
      flex/margin-top:auto trick below. /admin is gated by the auth
      middleware, so public visitors who click it just see the login
      screen — no harm. Visually a footnote, not a nav item. */}
  <a href="/admin" class="sidebar-admin">Admin</a>
</nav>

<style>
  /* Make the sidebar a flex column with full available height so
     `margin-top: auto` on the admin link pushes it to the bottom.
     Add a soft oxblood wash so the sidebar feels like the same warm
     accent family as the admin topbar, without obscuring the dragon-
     scale watermark or hurting text contrast. The gradient deepens
     toward the bottom for a faint chiaroscuro. */
  .sidebar {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 48px);
    /* Wine-red wash, matching the admin topbar's chromatic family.
       Oxblood (#6b2820) was reading too warm/brown over parchment;
       rgb(120,24,28) is the same depth but cooler — more cherry, less
       umber — so it mixes with the cream paper into a true red rather
       than a dusty rose. Gradient deepens toward the bottom for
       weight without obscuring the dragon scales. */
    background-image: linear-gradient(
      180deg,
      rgba(120, 24, 28, 0.20) 0%,
      rgba(120, 24, 28, 0.34) 40%,
      rgba(120, 24, 28, 0.48) 100%
    );
    padding-right: 18px;
    border-right: 1px solid rgba(120, 24, 28, 0.55);
    box-shadow: inset -1px 0 0 rgba(120, 24, 28, 0.18);
  }
  .sidebar-admin {
    display: block;
    margin-top: auto;          /* push to bottom of the sidebar column */
    padding-top: 80px;          /* extra cushion above */
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.22;
    color: var(--ink-soft, #5a4d33);
    text-decoration: none;
    transition: opacity 0.2s, color 0.2s;
  }
  .sidebar-admin:hover {
    opacity: 0.85;
    color: var(--accent-2);
  }
</style>
