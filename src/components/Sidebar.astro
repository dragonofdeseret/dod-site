---
// ──────────────────────────────────────────────────────────────────────────────
// Sidebar — single nav definition, replaces the 18 copy-pasted sidebars in
// the legacy site. Pass `active` to highlight the current top-level link.
//
//   <Sidebar active="archive" />
//
// `subActive` highlights a sub-nav link (e.g. "altered-states" under Writing).
// ──────────────────────────────────────────────────────────────────────────────

interface Props {
  active?:
    | 'home'
    | 'archive'
    | 'art'
    | 'writing'
    | 'now'
    | 'prints'
    | 'questions'
    | 'bio'
  subActive?:
    // Art sub-nav
    | 'exhibits'
    | 'photo'
    // Writing sub-nav
    | 'altered-states'
    | 'margins'
    | 'quotes'
}

const { active, subActive } = Astro.props

// Helper to flag the active class without polluting template-side logic.
const cls = (key: NonNullable<Props['active']>) =>
  active === key ? 'active' : undefined
const subCls = (key: NonNullable<Props['subActive']>) =>
  subActive === key ? 'nav-sub active' : 'nav-sub'
---

<nav class="sidebar">
  <h1>Christopher Shenefelt</h1>

  <a href="/" class={cls('home')}>Home</a>
  <a href="/archive" class={cls('archive')}>Archive</a>

  <a href="/art" class={cls('art')}>Artwork</a>
  {active === 'art' && (
    <>
      <a href="/exhibits" class={subCls('exhibits')}>Exhibits</a>
      <a href="/photography" class={subCls('photo')}>Photography</a>
    </>
  )}

  <a href="/writing" class={cls('writing')}>Writing</a>
  {active === 'writing' && (
    <>
      <a href="/altered-states" class={subCls('altered-states')}>Altered States</a>
      <a href="/margins" class={subCls('margins')}>Margins &amp; Excerpts</a>
      <a href="/quotes" class={subCls('quotes')}>Quotes from Others</a>
    </>
  )}

  <a href="/now" class={cls('now')}>Now</a>
  <a href="/prints" class={cls('prints')}>Prints</a>
  <a href="/questions" class={cls('questions')}>Questions</a>
  <a href="/bio" class={cls('bio')}>Biography</a>

  {/* External links (Harmonic Theism, Dao De Zion, Instagram, X) all
      live in the footer now — duplicating them in the sidebar muddied
      the navigation. Sidebar is purely first-party site sections.

      No visible Admin link — keeps the public surface clean. The
      admin is reachable by typing /admin/login directly. The middleware
      gates everything underneath, so even if a visitor stumbles on
      the URL they just see the login screen and can't get further. */}
</nav>

<style>
  /* Make the sidebar a flex column with full available height so
     `margin-top: auto` on the admin link pushes it to the bottom.
     Add a soft oxblood wash so the sidebar feels like the same warm
     accent family as the admin topbar, without obscuring the dragon-
     scale watermark or hurting text contrast. The gradient deepens
     toward the bottom for a faint chiaroscuro. */
  .sidebar {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 48px);
    /* Wine-plum wash. Shifted from the topbar's red-leaning
       rgb(48,12,14) toward purple by lifting the B channel —
       rgb(58,14,42) is a deep mulberry that reads as "wine with a
       violet undertone" instead of pure red. Pushed deeper still at
       the bottom so the column has gallery-wall weight. */
    background-image: linear-gradient(
      180deg,
      rgba(58, 14, 42, 0.45) 0%,
      rgba(58, 14, 42, 0.68) 40%,
      rgba(58, 14, 42, 0.88) 100%
    );
    padding-right: 18px;
    border-right: 1px solid rgba(58, 14, 42, 0.92);
    box-shadow: inset -1px 0 0 rgba(58, 14, 42, 0.35);
  }
  /* Sidebar text legibility on the dark wine-plum wash. Default text
     colors (var(--ink), var(--ink-soft), var(--ink-faint)) are too
     dark to read at the deeper gradient stops; switching to paper-
     leaning shades so every line is legible from top to bottom.
     Hover and active states stay distinctly brighter than rest. */
  .sidebar :global(h1 a) {
    color: rgba(236, 226, 197, 0.95);
  }
  .sidebar :global(h1 a:hover) {
    color: #ffffff;
  }
  .sidebar :global(> a) {
    color: rgba(236, 226, 197, 0.78);
  }
  .sidebar :global(> a:hover) {
    color: #ffffff;
  }
  .sidebar :global(> a.active) {
    color: var(--paper, #ece2c5);
    font-weight: 600;
  }
  .sidebar :global(.nav-sub) {
    color: rgba(236, 226, 197, 0.7);
    font-size: 13px;
  }
  .sidebar :global(.nav-sub:hover) {
    color: #ffffff;
  }
  .sidebar :global(.nav-sub.active) {
    color: var(--paper, #ece2c5);
    font-weight: 600;
  }
</style>
