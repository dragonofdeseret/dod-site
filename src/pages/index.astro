---
// ──────────────────────────────────────────────────────────────────────────────
// / — homepage. Library design system, "real entry point" structure:
//   • Typographic identity (masthead)
//   • Voice statement (who/what/why — 2-4 sentences)
//   • Featured (latest essay surfaced prominently)
//   • Sections-as-invitations (each major area with a one-line description
//     of what's there)
//   • Latest activity (5 most recent items across types)
//   • Colophon footer (RSS, second domain note, etc.)
//
// Drops the sidebar entirely on this page — the visitor needs an
// invitation, not a navigation panel. Sidebar reappears on every
// inner route.
// ──────────────────────────────────────────────────────────────────────────────

// Static prerender — built at deploy time. Astro emits HTML; no
// serverless function. Admin routes opt OUT with prerender = false.
export const prerender = true

import { getCollection } from 'astro:content'
import HomeLayout from '../layouts/HomeLayout.astro'
import { publicOnly } from '../lib/sort-group'

// Pull every collection so we can surface a curated featured + latest.
const [art, photo, writing, margins, quotes] = await Promise.all([
  getCollection('art').then(publicOnly),
  getCollection('photo').then(publicOnly),
  getCollection('writing').then(publicOnly),
  getCollection('margins'),
  getCollection('quotes'),
])

// Featured = most recent non-trip-report essay. If none, fall back to
// most recent margin. The point is to lead the visitor into the
// thinking, not the gallery.
const writingSorted = [...writing]
  .filter((w) => !(Array.isArray(w.data.sections) && w.data.sections.includes('trips')))
  .sort((a, b) => Date.parse(b.data.date) - Date.parse(a.data.date))
const featured = writingSorted[0] ?? null

// Latest = 5 most recent items across writing/art/photo/margins.
type Dated = { collection: string; data: { id?: string; title?: string; date?: string } }
const latestAll: Dated[] = [
  ...writing.map((w) => ({ collection: 'writing', data: w.data })),
  ...art.map((a) => ({ collection: 'art', data: a.data })),
  ...photo.map((p) => ({ collection: 'photo', data: p.data })),
  ...margins.map((m) => ({ collection: 'margins', data: m.data })),
]
const latest = latestAll
  .filter((it) => it.data.date)
  .sort((a, b) => Date.parse(b.data.date!) - Date.parse(a.data.date!))
  .slice(0, 5)

// Section descriptors — these read like a magazine's table of contents,
// not just nav. Each one tells the visitor what kind of material lives
// there.
const sections = [
  {
    href: '/writing',
    eyebrow: 'Essays',
    title: 'Writing',
    body: 'Long-form pieces on harmonic theism, Mormon metaphysics, phenomenology of altered states, and the texture of belief.',
    count: writing.length,
  },
  {
    href: '/art',
    eyebrow: 'Studio',
    title: 'Artwork',
    body: 'Artpocrypha.',
    count: art.length,
  },
  {
    href: '/photography',
    eyebrow: 'Lens',
    title: 'Photography',
    body: 'Field notes from the eye.',
    count: photo.length,
  },
  {
    href: '/margins',
    eyebrow: 'Notes',
    title: 'Margins & Excerpts',
    body: 'Marginalia from the books, the dreams, the long conversations. Short forms.',
    count: margins.length,
  },
  {
    href: '/altered-states',
    eyebrow: 'Reports',
    title: 'Altered States',
    body: 'Field notes and phenomenology from Altered States: Vision, Sleep Paralysis, Meditation, Cannabis, LSD, DMT, Psilocybin.',
    count: writing.filter((w) => Array.isArray(w.data.sections) && w.data.sections.includes('trips')).length,
  },
  {
    href: '/now',
    eyebrow: 'Current',
    title: 'Now',
    body: 'What I am painting, writing, and reading at this moment.',
    count: null,
  },
]

// A featured quote rotates daily based on the date — picks one of the
// quotes collection entries deterministically. No JS required.
const today = new Date()
const dayIndex =
  today.getUTCFullYear() * 1000 + today.getUTCMonth() * 50 + today.getUTCDate()
const quoteOfDay = quotes.length > 0 ? quotes[dayIndex % quotes.length] : null
---

<HomeLayout title="Home">
  <div class="home">
    {/* ── Masthead ───────────────────────────────────────────────── */}
    <header class="home__masthead">
      <h1 class="home__name">Christopher Shenefelt</h1>
      <p class="home__monicker">The Dragon of Deseret</p>
      <div class="home__rule" />
    </header>

    {/* ── Voice / opening invocation ──────────────────────────────── */}
    <section class="home__voice">
      <p class="home__voice-lead">A Living Archive.</p>
      <p class="home__voice-text">
        Art. Photography. Thoughts on Mormonism, Daoism, Zen,
        Consciousness, and Phenomenology.
      </p>
    </section>

    {/* ── Featured book: Harmonic Theism ─────────────────────────────
       Sits above the latest essay because it's the centerpiece work.
       Two-column on desktop (cover left, copy right), stacked on
       mobile. Direct link to Amazon. */}
    <section class="home__book">
      <a class="home__book-link" href="/harmonic-theism">
        <div class="home__book-cover">
          <img
            src="/images/book/ht-cover.png"
            alt="Harmonic Theism: Symphony No. I — book cover"
            width="220"
            height="330"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="home__book-body">
          <div class="home__book-eyebrow eyebrow">New Release · Symphony No. I</div>
          <h2 class="home__book-title">Harmonic Theism</h2>
          <p class="home__book-subtitle">
            <em>Creatio ex Concordia and the Divine Arrangement of Worlds</em>
          </p>
          <p class="home__book-blurb">
            A symphonic theology in eight movements. The first volume reframes
            the central attributes of God not as static absolutes but as living
            harmonics — omniscience as <em>shared knowing</em>, omnipresence as
            <em>manifest resonance</em>, omnipotence as <em>collaboration</em>,
            eternity as <em>cadence</em>. Weaving LDS theology with Daoism,
            Zen, contemporary science and literature, and more, it proposes
            <em>creatio ex concordia</em> — creation from harmony — as the
            most coherent way to read both the cosmos and the soul.
          </p>
          <span class="home__book-cta">Read more →</span>
        </div>
      </a>
    </section>

    {/* ── Featured essay ───────────────────────────────────────────── */}
    {featured && (
      <section class="home__featured">
        <div class="home__featured-eyebrow eyebrow">Featured · Latest essay</div>
        <h2 class="home__featured-title">
          <a href={`/writing/${featured.data.id}`}>
            {featured.data.title.includes(' | ') ? (
              <>
                <span class="home__featured-title-main">
                  {featured.data.title.split(' | ')[0]}
                </span>
                <span class="home__featured-title-sub">
                  | {featured.data.title.split(' | ').slice(1).join(' | ')}
                </span>
              </>
            ) : (
              featured.data.title
            )}
          </a>
        </h2>
        {featured.data.tags && featured.data.tags.length > 0 && (
          <div class="home__featured-tags">
            {featured.data.tags.slice(0, 5).map((t) => (
              <span class="home__tag">{t}</span>
            ))}
          </div>
        )}
        <a class="home__featured-read" href={`/writing/${featured.data.id}`}>
          Read the essay →
        </a>
      </section>
    )}

    {/* ── Sections (the table of contents, as invitation) ─────────── */}
    <section class="home__sections">
      <div class="home__section-header eyebrow">Sections</div>
      <ul class="home__section-list">
        {sections.map((s) => (
          <li class="home__section-row">
            <a href={s.href} class="home__section-link">
              <div class="home__section-eyebrow">{s.eyebrow}</div>
              <h3 class="home__section-title">{s.title}</h3>
              <p class="home__section-body">{s.body}</p>
              {s.count !== null && (
                <span class="home__section-count">
                  {s.count} {s.count === 1 ? 'entry' : 'entries'}
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>

    {/* ── Latest activity ────────────────────────────────────────── */}
    <section class="home__latest">
      <div class="home__section-header eyebrow">Recently added</div>
      <ul class="home__latest-list">
        {latest.map((it) => {
          const url =
            it.collection === 'writing'
              ? `/writing/${it.data.id}`
              : it.collection === 'art'
                ? `/art/${it.data.id}`
                : it.collection === 'photo'
                  ? `/photography/${it.data.id}`
                  : `/margins#${it.data.id}`
          return (
            <li class="home__latest-row">
              <span class="home__latest-kind">{it.collection}</span>
              <a class="home__latest-title" href={url}>
                {it.data.title}
              </a>
              <span class="home__latest-date mono">{it.data.date}</span>
            </li>
          )
        })}
      </ul>
    </section>

    {/* ── Quote of the day ───────────────────────────────────────── */}
    {quoteOfDay && (
      <>
        <hr class="asterism" />
        <section class="home__quote">
          <blockquote class="home__quote-text">
            {(quoteOfDay.body ?? '').trim()}
            <cite>
              {quoteOfDay.data.author}
              {quoteOfDay.data.source && (
                <span class="home__quote-source"> · {quoteOfDay.data.source}</span>
              )}
            </cite>
          </blockquote>
        </section>
      </>
    )}

    {/* ── Colophon footer ────────────────────────────────────────── */}
    <footer class="home__colophon">
      <div class="home__colophon-rule" />
      <div class="home__colophon-grid">
        <div>
          <div class="eyebrow">About</div>
          <p>
            <a href="/bio">Biography</a> · <a href="/questions">Questions</a>
          </p>
        </div>
        <div>
          <div class="eyebrow">Works</div>
          <p>
            <a
              href="https://a.co/d/04zcw8xP"
              target="_blank"
              rel="noopener"
            >
              Harmonic Theism ↗
            </a>{' '}
            ·{' '}
            <a
              href="https://daodezion.com"
              target="_blank"
              rel="noopener"
            >
              Dao De Zion ↗
            </a>{' '}
            ·{' '}
            <a
              href="https://valencejournal.com"
              target="_blank"
              rel="noopener"
            >
              Valence Journal ↗
            </a>{' '}
            ·{' '}
            <a
              href="https://contextualology.com"
              target="_blank"
              rel="noopener"
            >
              Contextualology ↗
            </a>
          </p>
        </div>
        <div>
          <div class="eyebrow">Elsewhere</div>
          <p>
            <a
              href="https://www.instagram.com/dragonofdeseret/"
              target="_blank"
              rel="noopener"
            >
              Instagram ↗
            </a>{' '}
            ·{' '}
            <a
              href="https://x.com/dragonofdeseret"
              target="_blank"
              rel="noopener"
            >
              X ↗
            </a>
          </p>
        </div>
      </div>
      <p class="home__colophon-mark mono">
        © {new Date().getFullYear()} Christopher Shenefelt · the Dragon of Deseret
        · artwork and writing © their respective years
      </p>
    </footer>
  </div>
</HomeLayout>

<style>
  /* ──────────────────────────────────────────────────────────────────────
     Homepage-specific layout. Uses the same tokens as global.css.
     Structure: centered single column, generous vertical rhythm, no
     sidebar. Reads as a magazine cover.
     ────────────────────────────────────────────────────────────────────── */

  .home {
    max-width: 760px;
    margin: 0 auto;
    padding: 80px 32px 120px;
  }

  /* ── Masthead ──────────────────────────────────────────────────────── */
  .home__masthead {
    text-align: center;
    margin-bottom: 36px;
  }
  .home__name {
    font-family: 'Marcellus', serif;
    font-size: var(--fs-display);
    font-weight: 400;
    letter-spacing: 0.01em;
    line-height: 1.1;
    margin: 0;
    color: var(--ink);
  }
  /* Monicker — identifying epithet under the name. Small caps in
     oxblood, generous letter-spacing. Reads like a printed-book
     subtitle line ("known as", "or"). */
  .home__monicker {
    /* Sit a little further off the main name so the small caps don't
       feel crammed against the descenders. */
    margin: 1.1em 0 0 0;
    font-family: 'Source Serif 4', serif;
    font-variant: small-caps;
    font-feature-settings: 'smcp', 'c2sc';
    letter-spacing: 0.18em;
    font-size: 13px;
    color: var(--accent-2);
    line-height: 1;
  }
  .home__tagline {
    margin: 1em 0 0 0;
    font-style: italic;
    color: var(--ink-soft);
    font-size: var(--fs-lg);
  }
  .home__rule {
    width: 80px;
    height: 1px;
    background: var(--rule);
    margin: 28px auto 0;
  }

  /* ── Voice ─────────────────────────────────────────────────────────── */
  .home__voice {
    margin: 0 0 64px 0;
    text-align: center;
  }
  .home__voice-lead {
    font-family: 'Marcellus', serif;
    font-style: italic;
    font-size: 30px;
    color: var(--accent-2);
    margin: 0 0 0.5em 0;
    line-height: 1.2;
  }
  .home__voice-text {
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
    font-style: italic;
  }

  /* ── Featured book (Harmonic Theism) ───────────────────────────────────
     Two-column on desktop: cover on the left, copy on the right. Same
     palette as the featured-essay card so they read as a pair, but with
     a slightly deeper paper fill + warmer hairline + a faint oxblood
     glow so the book reads as the headline piece. Hover lifts the whole
     card subtly. Stacks vertically on narrow viewports. */
  .home__book {
    margin: 0 0 36px 0;
  }
  .home__book-link {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 32px;
    align-items: start;
    padding: 32px 36px;
    background-color: rgba(236, 226, 197, 0.6);
    background-image:
      linear-gradient(180deg, rgba(58, 14, 42, 0.05) 0%, rgba(58, 14, 42, 0.09) 100%),
      url('/dragon-scales.svg');
    border: 1px solid var(--paper-edge);
    border-radius: var(--radius-lg);
    box-shadow: inset 0 0 0 1px rgba(236, 226, 197, 0.5),
                0 2px 12px rgba(58, 14, 42, 0.06);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s, border-color 0.18s, box-shadow 0.18s;
  }
  .home__book-link:hover {
    transform: translateY(-2px);
    border-color: var(--accent-2);
    box-shadow: inset 0 0 0 1px rgba(236, 226, 197, 0.5),
                0 6px 22px rgba(58, 14, 42, 0.14);
  }
  .home__book-cover {
    aspect-ratio: 2 / 3;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 4px 14px rgba(31, 26, 16, 0.28),
                0 1px 0 rgba(255, 255, 255, 0.25) inset;
  }
  .home__book-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .home__book-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .home__book-eyebrow {
    color: var(--accent-2);
  }
  .home__book-title {
    font-family: 'Marcellus', serif;
    font-size: 38px;
    line-height: 1.1;
    margin: 4px 0 0 0;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .home__book-subtitle {
    font-family: 'Marcellus', serif;
    color: var(--ink-soft);
    font-size: 16px;
    margin: 4px 0 16px 0;
    line-height: 1.35;
  }
  .home__book-blurb {
    margin: 0 0 18px 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-soft);
  }
  .home__book-blurb em {
    color: var(--ink);
    font-style: italic;
  }
  .home__book-cta {
    display: inline-block;
    align-self: start;
    padding: 10px 22px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 999px;
    font-family: 'Marcellus', serif;
    font-size: 13px;
    letter-spacing: 0.06em;
    transition: background-color 0.15s;
  }
  .home__book-link:hover .home__book-cta {
    background: var(--accent-2);
  }
  @media (max-width: 640px) {
    .home__book-link {
      grid-template-columns: 1fr;
      padding: 24px;
      gap: 20px;
    }
    .home__book-cover {
      max-width: 200px;
      margin: 0 auto;
    }
    .home__book-title {
      font-size: 30px;
      text-align: center;
    }
    .home__book-subtitle,
    .home__book-eyebrow {
      text-align: center;
    }
  }

  /* ── Featured ──────────────────────────────────────────────────────────
     Semi-transparent pill fill — separates the featured essay from the
     page rhythm visually, but lets the dragon-scale watermark show
     through. The fill is `paper-warm` at ~55% alpha; the hairline border
     keeps the shape definite. Rounded corners give the pill feel.
     ───────────────────────────────────────────────────────────────────── */
  .home__featured {
    margin: 0 0 64px 0;
    padding: 36px 44px;
    background: rgba(224, 212, 177, 0.5);
    border: 1px solid var(--paper-edge);
    border-radius: var(--radius-lg);
    text-align: center;
  }
  .home__featured-eyebrow {
    margin: 0 0 14px 0;
  }
  .home__featured-title {
    font-family: 'Marcellus', serif;
    font-size: 36px;
    margin: 0 0 14px 0;
    line-height: 1.15;
    color: var(--ink);
  }
  .home__featured-title a {
    color: var(--ink);
    text-decoration: none;
    display: inline-block;
  }
  .home__featured-title a:hover { color: var(--accent-2); }
  /* When the title carries a " | subtitle" tail, stack it: main title
     stays one (visually unbroken) line, the subtitle drops to a softer
     second line headed by the pipe — title-and-subtitle composition,
     independent of the card's width. */
  .home__featured-title-main {
    display: block;
  }
  .home__featured-title-sub {
    display: block;
    margin-top: 6px;
    font-size: 0.7em;
    font-style: italic;
    color: var(--ink-soft, #5a4d33);
    letter-spacing: 0.01em;
  }
  .home__featured-tags {
    margin-bottom: 18px;
  }
  .home__tag {
    font-variant: small-caps;
    letter-spacing: 0.05em;
    font-size: 12px;
    color: var(--ink-faint);
    font-style: italic;
    margin: 0 0.5em;
  }
  .home__featured-read {
    display: inline-block;
    font-variant: small-caps;
    letter-spacing: 0.12em;
    font-size: var(--fs-sm);
    color: var(--accent-2);
    text-decoration: none;
  }
  .home__featured-read:hover {
    color: var(--accent);
  }

  /* ── Sections ──────────────────────────────────────────────────────── */
  .home__sections {
    margin: 0 0 64px 0;
  }
  .home__section-header {
    margin-bottom: 24px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--rule);
  }
  .home__section-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px 36px;
  }
  .home__section-row {
    /* placeholder for future per-row tweaks */
  }
  .home__section-link {
    display: block;
    text-decoration: none;
    color: var(--ink);
    /* Pill-fill card so each section invitation reads as its own object.
       Same semi-transparent paper fill as the featured essay so the
       dragon-scale watermark bleeds through quietly. */
    background: var(--paper-fill);
    border: 1px solid var(--paper-edge);
    border-radius: var(--radius-lg);
    padding: 18px 22px;
    height: 100%;
    transition: border-color 150ms ease, transform 150ms ease;
  }
  .home__section-link:hover {
    border-color: var(--accent-2);
    transform: translateY(-1px);
  }
  .home__section-eyebrow {
    font-variant: small-caps;
    letter-spacing: 0.1em;
    font-size: 11px;
    color: var(--ink-faint);
    margin-bottom: 2px;
  }
  .home__section-title {
    font-family: 'Marcellus', serif;
    font-size: 22px;
    margin: 0 0 6px 0;
    color: var(--ink);
    line-height: 1.2;
  }
  .home__section-link:hover .home__section-title {
    color: var(--accent);
  }
  .home__section-body {
    margin: 0 0 8px 0;
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.55;
  }
  .home__section-count {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.02em;
  }

  /* ── Latest ────────────────────────────────────────────────────────── */
  .home__latest {
    margin: 0 0 64px 0;
  }
  .home__latest-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .home__latest-row {
    display: grid;
    grid-template-columns: 84px 1fr auto;
    align-items: baseline;
    gap: 14px;
    /* Same semi-transparent pill treatment as everywhere else on the
       homepage. */
    padding: 14px 20px;
    background: var(--paper-fill);
    border: 1px solid var(--paper-edge);
    border-radius: var(--radius);
    transition: border-color 150ms ease;
  }
  .home__latest-row:hover {
    border-color: var(--accent-2);
  }
  .home__latest-kind {
    font-variant: small-caps;
    letter-spacing: 0.08em;
    font-size: 11px;
    color: var(--ink-faint);
  }
  .home__latest-title {
    color: var(--ink);
    text-decoration: none;
    font-size: 16px;
    line-height: 1.35;
  }
  .home__latest-title:hover {
    color: var(--accent);
    text-decoration-color: var(--rule);
  }
  .home__latest-date {
    font-size: 11px;
    color: var(--ink-faint);
  }

  /* ── Quote ─────────────────────────────────────────────────────────── */
  .home__quote {
    margin: 0 0 64px 0;
    /* Same pill treatment so the rotating quote feels like a curated
       fragment in its own card, not floating prose. */
    background: var(--paper-fill);
    border: 1px solid var(--paper-edge);
    border-radius: var(--radius-lg);
    padding: 36px 44px;
  }
  .home__quote-text {
    font-style: italic;
    font-size: 21px;
    line-height: 1.5;
    color: var(--ink);
    border-left: none;
    padding: 0;
    margin: 0;
    text-align: center;
  }
  .home__quote-text cite {
    display: block;
    margin-top: 14px;
    font-variant: small-caps;
    letter-spacing: 0.1em;
    font-size: 12px;
    font-style: normal;
    color: var(--ink-faint);
  }
  .home__quote-source {
    color: var(--ink-faint);
  }

  /* ── Colophon ──────────────────────────────────────────────────────── */
  .home__colophon {
    margin-top: 80px;
  }
