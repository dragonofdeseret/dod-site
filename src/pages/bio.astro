---
// Static prerender — built at deploy time.
export const prerender = true

// ──────────────────────────────────────────────────────────────────────────────
// /bio — biography page. Content is admin-editable; all data lives in
// src/content/site/bio.md and is parsed into three sections:
//
//   ## profile     — key/value rows for the archive-entry panel
//                    (Type, Region, Traditions, Methods, etc.)
//   ## background  — key/value rows rendered as the "Background" cell's
//                    bulleted list (Previous, Current)
//   ## timeline    — date-blocks separated by blank lines.
//                    First line = date label, remaining lines = description.
//                    Lines starting with `- ` become bullets.
//                    Markdown links [text](url) become anchors.
//
// Edit at /admin/site/bio (same flow as the Now page).
// ──────────────────────────────────────────────────────────────────────────────

import { getEntry } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'

const entry = await getEntry('site', 'bio')
const body = entry?.body ?? ''

// ── Markdown helpers ──────────────────────────────────────────────────────
// Inline `[text](url)`, `**bold**`, `_italic_` → HTML. Everything else
// is escaped. Keeps the surface area small and predictable for the admin.
function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
}
function inlineMd(s: string): string {
  // Escape first, then do the markdown substitutions on the escaped text
  // so any user-typed angle brackets stay literal.
  let out = escapeHtml(s)
  // [text](url) — only the basic http(s) and root-relative URLs
  out = out.replace(
    /\[([^\]]+)\]\(((?:https?:\/\/|\/)[^)\s]+)\)/g,
    (_m, text, url) => `<a href="${url}">${text}</a>`,
  )
  // **bold**
  out = out.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
  // _italic_
  out = out.replace(/(^|\s)_([^_]+)_(?=\s|$)/g, '$1<em>$2</em>')
  return out
}

// ── Parse the body into sections ──────────────────────────────────────────
function splitSections(md: string): Record<string, string[]> {
  const sections: Record<string, string[]> = {}
  let current: string | null = null
  for (const rawLine of md.split('\n')) {
    const line = rawLine.replace(/\r$/, '')
    const m = /^##\s+(.+)$/.exec(line)
    if (m) {
      current = m[1].trim().toLowerCase()
      sections[current] = []
      continue
    }
    if (current) sections[current].push(line)
  }
  return sections
}

// `- Key: Value` rows. Returns array preserving order so the page can
// render fields in the sequence the admin wrote them. Accepts -, –, —,
// •, * as the bullet marker (iOS Smart Punctuation auto-converts `- `
// to `– ` on phone keyboards, which would otherwise drop the row).
function parseKeyValue(lines: string[]): Array<{ key: string; value: string }> {
  const rows: Array<{ key: string; value: string }> = []
  for (const line of lines) {
    const m = /^\s*[-–—•*]\s+([^:]+):\s*(.*)$/.exec(line)
    if (!m) continue
    rows.push({ key: m[1].trim(), value: m[2].trim() })
  }
  return rows
}

// Timeline: blocks separated by blank lines. First non-blank line is the
// date; remaining lines are body. Body lines beginning with `- ` become
// bullets; everything else is rendered as plain text (with inline md).
interface TimelineEntry {
  date: string
  bullets: string[]
  paragraphs: string[]
}
function parseTimeline(lines: string[]): TimelineEntry[] {
  const out: TimelineEntry[] = []
  let cur: TimelineEntry | null = null
  for (const rawLine of lines) {
    const line = rawLine.trim()
    if (!line) {
      if (cur) {
        out.push(cur)
        cur = null
      }
      continue
    }
    if (!cur) {
      cur = { date: line, bullets: [], paragraphs: [] }
      continue
    }
    // Accept any common bullet marker — iOS Smart Punctuation
    // auto-converts `- ` to `– ` on phone keyboards.
    const bulletMatch = /^[-–—•*]\s+(.*)$/.exec(line)
    if (bulletMatch) {
      cur.bullets.push(bulletMatch[1].trim())
    } else {
      cur.paragraphs.push(line)
    }
  }
  if (cur) out.push(cur)
  return out
}

const sections = splitSections(body)
const profile = parseKeyValue(sections['profile'] ?? [])
const background = parseKeyValue(sections['background'] ?? [])
const timeline = parseTimeline(sections['timeline'] ?? [])
---

<BaseLayout title="Biography" active="bio">
  <div class="bio-page-wrap">
    <header class="page-header">
      <h1>Biography</h1>
      <p class="page-intro"></p>
    </header>

    <section class="bio-shell bio-archive-layout">
      <article class="bio-panel archive-entry">
        <div class="archive-entry-head">
          <h2>Christopher Shenefelt</h2>
          <div class="archive-id">ID: HUMAN-1989-UT-USA</div>
          <div class="archive-status">STATUS: ACTIVE</div>
        </div>

        <div class="archive-grid">
          {profile.map((row) => (
            row.key.toLowerCase() === 'background' ? null : (
              <div class="archive-row">
                <div class="archive-key">{row.key}</div>
                <div class="archive-value" set:html={inlineMd(row.value)} />
              </div>
            )
          ))}
          {background.length > 0 && (
            <div class="archive-row">
              <div class="archive-key">Background</div>
              <div class="archive-value">
                <ul class="archive-list">
                  {background.map((b) => (
                    <li>
                      <strong>{b.key}:</strong>
                      <Fragment set:html={' ' + inlineMd(b.value)} />
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )}
        </div>
      </article>

      <aside class="bio-aside timeline-panel">
        <div class="bio-kicker">Life Index</div>
        <div class="timeline-scroll">
          {timeline.map((t) => (
            <div class="timeline-item">
              <div class="timeline-year">{t.date}</div>
              <div class="timeline-text">
                {t.bullets.length > 0 ? (
                  <ul class="timeline-bullets">
                    {t.bullets.map((b) => (
                      <li set:html={inlineMd(b)} />
                    ))}
                  </ul>
                ) : (
                  t.paragraphs.map((p) => (
                    <div set:html={inlineMd(p)} />
                  ))
                )}
              </div>
            </div>
          ))}
        </div>
      </aside>
    </section>
  </div>
</BaseLayout>

<style>
  .bio-page-wrap { /* sentinel for any future bio-specific overrides */ }
  /* Reset the bullet list inside timeline entries so it doesn't inherit
     the default browser ~40px indent. Tighter spacing + small dot
     markers that match the rest of the library palette. */
  .timeline-bullets {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .timeline-bullets li {
    padding: 2px 0;
  }
  .timeline-bullets li::before {
    content: '·';
    color: var(--accent-2);
    margin-right: 8px;
    font-weight: 700;
  }
</style>
