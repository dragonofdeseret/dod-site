---
// Static prerender — built at deploy time. Astro emits HTML; no
// serverless function. Admin routes opt OUT with prerender = false.
export const prerender = true

// ──────────────────────────────────────────────────────────────────────────────
// /art/[id] — single artwork viewer page. Markup mirrors legacy
// buildArtworkPage() output (.art-page > h1#title + .art-navigation#nav +
// #art-layout > .media-row > .media-image + .media-note).
//
// Astro pre-generates a static page per art item via `getStaticPaths`.
// prev/next navigation is computed at build time from the chronological
// art ordering.
//
// Click on the image opens the lightbox (full-resolution source). ESC /
// click-outside closes; arrow keys nav between items.
// ──────────────────────────────────────────────────────────────────────────────

import type { GetStaticPaths } from 'astro'
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import BuyPrint from '../../components/BuyPrint.astro'
import { sortByDateDescWithIdTiebreak } from '../../lib/sort-group'
import { viewerSrc, viewerSrcset, originalSrc, VIEWER_SIZES } from '../../lib/images'

export const getStaticPaths = (async () => {
  const items = sortByDateDescWithIdTiebreak(await getCollection('art'))
  return items.map((item, i) => {
    const prev = items[i - 1] ?? null
    const next = items[i + 1] ?? null
    return {
      params: { id: item.data.id },
      props: { item, prev, next },
    }
  })
}) satisfies GetStaticPaths

const { item, prev, next } = Astro.props
const fromParam = Astro.url.searchParams.get('from') ?? 'art'

// Back-link copy depends on `from` so visitors who landed here from
// /archive or /exhibits return to the right place.
const back =
  fromParam === 'archive'
    ? { href: '/archive', text: 'Back to Archive' }
    : fromParam === 'exhibit'
      ? { href: '/exhibits', text: 'Back to Exhibits' }
      : { href: '/art', text: 'Back to Artwork' }

const prevUrl = prev ? `/art/${prev.data.id}?from=${fromParam}` : ''
const nextUrl = next ? `/art/${next.data.id}?from=${fromParam}` : ''
---

<BaseLayout title={item.data.title} active="art">
  <div class="art-page">
    <h1 id="title">{item.data.title}</h1>

    <div class="art-navigation" id="nav">
      <div class="nav-left">
        {prev && <a href={prevUrl}>← Previous</a>}
      </div>
      <div class="nav-center">
        <a href={back.href}>{back.text}</a>
      </div>
      <div class="nav-right">
        {next && <a href={nextUrl}>Next →</a>}
      </div>
    </div>

    {item.data.forSale && item.data.prints && item.data.prints.length > 0 && (
      <BuyPrint artworkId={item.data.id} prints={item.data.prints} />
    )}

    <div id="art-layout">
      {item.data.sideNote ? (
        <div class="media-row">
          <div class="media-image">
            <img
              id="art-image"
              src={viewerSrc(item.data.image)}
              srcset={viewerSrcset(item.data.image)}
              sizes={VIEWER_SIZES}
              decoding="async"
              alt={item.data.title}
              data-lightbox={originalSrc(item.data.image)}
              style="cursor: zoom-in"
            />
          </div>
          <aside class="media-note">
            <h3>{item.data.sideNoteTitle ?? 'Details'}</h3>
            <Fragment set:html={item.data.sideNote} />
          </aside>
        </div>
      ) : (
        <div class="art-image">
          <img
            id="art-image"
            src={viewerSrc(item.data.image)}
            srcset={viewerSrcset(item.data.image)}
            sizes={VIEWER_SIZES}
            decoding="async"
            alt={item.data.title}
            data-lightbox={originalSrc(item.data.image)}
            style="cursor: zoom-in"
          />
        </div>
      )}
    </div>
  </div>

  {/* Lightbox + arrow-key navigation. The lightbox module auto-binds
      every [data-lightbox] on mount; the small inline script wires
      left/right arrows to the prev/next URLs. */}
  <script>
    import '../../scripts/lightbox.ts'
  </script>
  <script define:vars={{ prevUrl, nextUrl }}>
    document.addEventListener('keydown', (e) => {
      if (document.querySelector('.image-viewer')) return
      if (e.key === 'ArrowLeft' && prevUrl) window.location.href = prevUrl
      if (e.key === 'ArrowRight' && nextUrl) window.location.href = nextUrl
    })
  </script>
</BaseLayout>
