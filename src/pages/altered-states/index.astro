---
// Static prerender — built at deploy time. Astro emits HTML; no
// serverless function. Admin routes opt OUT with prerender = false.
export const prerender = true

// ──────────────────────────────────────────────────────────────────────────────
// /altered-states — trip-report index (writing entries flagged with
// sections: ['trips']). Same row layout as /writing; the title differs
// and the inline pills include `substance` in addition to `tags`.
//
// Substance + tag filter slots are present in the markup; client-side
// filter wiring is the next pass.
// ──────────────────────────────────────────────────────────────────────────────

import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { groupByYear } from '../../lib/sort-group'

const writing = await getCollection('writing')
const trips = writing.filter(
  (it) => Array.isArray(it.data.sections) && it.data.sections.includes('trips'),
)
const grouped = groupByYear(trips)
---

<BaseLayout title="Altered States" active="writing" subActive="altered-states">
  <header class="page-header">
    <h1>Altered States</h1>
    <p class="page-intro">trip reports</p>
    <nav class="year-nav">
      {grouped.map((g) => <a href={`#year-${g.year}`}>{g.year}</a>)}
    </nav>
    <div class="filter-block">
      <div class="filter-row">
        <div
          class="tag-filter tag-filter-tags"
          data-filter-name="tripTags"
          data-filter-target=".archive-list > .archive-row"
          data-filter-key="trip-tags"
          data-filter-mode="or"
        />
      </div>
    </div>
  </header>

  <div class="art-back">
    <a href="/writing">← Back to Writing</a>
  </div>

  <div id="trip-reports">
    {grouped.map((g) => (
      <div class="archive-year" id={`year-${g.year}`}>
        <h2>{g.year}</h2>
        <div class="archive-list">
          {g.items.map((it) => (
            <a
              class="archive-row"
              href={`/altered-states/${it.data.id}?from=trips`}
              data-trip-tags={(it.data.tags ?? []).join(',')}
            >
              <div class="archive-title">
                {it.data.title}
                {it.data.tags && it.data.tags.length > 0 && (
                  <div class="item-tags-inline">
                    {it.data.tags.map((t) => (
                      <span class="item-tag-inline">{t}</span>
                    ))}
                  </div>
                )}
              </div>
              <div class="archive-meta">{it.data.date || g.year}</div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

  <script>
    import '../../scripts/filter-engine.ts'
  </script>
</BaseLayout>
