---
// Static prerender — built at deploy time. Astro emits HTML; no
// serverless function. Admin routes opt OUT with prerender = false.
export const prerender = true

// ──────────────────────────────────────────────────────────────────────────────
// /altered-states/[id] — single trip-report viewer. Mirror of /writing/[id]
// but for entries flagged with sections: ['trips'].
// ──────────────────────────────────────────────────────────────────────────────

import type { GetStaticPaths } from 'astro'
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { publicOnly } from '../../lib/sort-group'

export const getStaticPaths = (async () => {
  const writing = publicOnly(await getCollection('writing'))
  const trips = writing.filter(
    (it) => Array.isArray(it.data.sections) && it.data.sections.includes('trips'),
  )
  return trips.map((item) => ({ params: { id: item.data.id }, props: { item } }))
}) satisfies GetStaticPaths

const { item } = Astro.props
const fromParam = Astro.url.searchParams.get('from') ?? 'trips'
const backHref = fromParam === 'archive' ? '/archive' : '/altered-states'
const backText =
  fromParam === 'archive' ? '← Back to Archive' : '← Back to Altered States'

const pdfSrc = `/${item.data.file}#zoom=page-width&view=FitH`
const pdfOpen = `/${item.data.file}`
---

<BaseLayout title={item.data.title} active="writing" subActive="altered-states">
  <header class="page-header">
    <h1>{item.data.title}</h1>
  </header>

  <div class="writing-actions">
    <a href={backHref}>{backText}</a>
    <a href={pdfOpen} target="_blank" rel="noopener">Enter Fullscreen</a>
  </div>

  <div class="essay-pdf">
    <div class="pdf-container">
      <iframe src={pdfSrc} title={item.data.title}></iframe>
    </div>
    <div class="pdf-mobile-link">
      <a href={pdfOpen} target="_blank" rel="noopener">Open PDF</a>
    </div>
  </div>
</BaseLayout>
