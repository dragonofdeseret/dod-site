---
// ──────────────────────────────────────────────────────────────────────────────
// /admin/auth-callback — magic-link landing page.
//
// Supabase redirects here after the user clicks the link in their email.
// The URL carries a `code` query param (or `#access_token=…` for older
// flows). We exchange it for a session, set the cookies, then bounce to
// wherever they were going (or /admin if no `next`).
// ──────────────────────────────────────────────────────────────────────────────

export const prerender = false

import { getServerSupabase } from '../../lib/supabase'

const supabase = getServerSupabase(Astro.cookies)
const url = Astro.url
const code = url.searchParams.get('code')
const next = url.searchParams.get('next') ?? '/admin'

let error: string | null = null
if (code) {
  const { error: exchangeErr } = await supabase.auth.exchangeCodeForSession(code)
  if (exchangeErr) {
    error = exchangeErr.message
  } else {
    return Astro.redirect(next)
  }
} else {
  // Older implicit flow puts the token in the URL hash (#access_token=…).
  // The hash isn't sent to the server, so we have to JS-bridge it: render
  // a tiny client snippet that calls supabase.auth.exchangeCodeForSession
  // via the JS client. Modern OTP flows use the `code` query param above,
  // but this fallback covers older Supabase configurations.
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Signing in…</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/global.css" />
  </head>
  <body class="admin-body">
    <div class="admin-login-wrap">
      <div class="admin-login-card">
        {error ? (
          <>
            <h1>Sign-in failed</h1>
            <div class="admin-flash admin-flash--error">{error}</div>
            <a class="admin-button admin-button--ghost" href="/admin/login">
              Try again
            </a>
          </>
        ) : (
          <>
            <h1>Signing you in…</h1>
            <p class="admin-flash admin-flash--info">
              If you're not redirected automatically, you can{' '}
              <a href={next}>continue here</a>.
            </p>
          </>
        )}
      </div>
    </div>

    {/* Hash-fragment fallback for implicit-grant flows. Reads the
        access_token + refresh_token from the URL hash, sets the
        Supabase session via the JS client, then redirects. No-op
        when the URL has no hash (modern OTP flow). */}
    <script define:vars={{ next }}>
      ;(async () => {
        if (!window.location.hash) return
        const hash = new URLSearchParams(window.location.hash.slice(1))
        const access_token = hash.get('access_token')
        const refresh_token = hash.get('refresh_token')
        if (!access_token || !refresh_token) return
        const { getBrowserSupabase } = await import('/src/lib/supabase.ts')
        const supabase = getBrowserSupabase()
        const { error } = await supabase.auth.setSession({
          access_token,
          refresh_token,
        })
        if (!error) window.location.replace(next)
      })().catch((e) => console.error(e))
    </script>
  </body>
</html>
