---
// ──────────────────────────────────────────────────────────────────────────────
// /admin/[collection]/[id] — single-entry editor. Handles both "new"
// (id="new") and edit-existing (id=actual). Renders a form whose
// fields match the collection's schema.
//
// All five collections share this route. The form fields vary per
// collection but the submit + media-upload flow is uniform (driven
// by data-attributes the client script reads).
// ──────────────────────────────────────────────────────────────────────────────

export const prerender = false

import { getEntry } from 'astro:content'
import AdminLayout from '../../../layouts/AdminLayout.astro'

const { collection, id } = Astro.params

const KNOWN = ['art', 'photo', 'writing', 'margins', 'quotes', 'site'] as const
type Known = (typeof KNOWN)[number]
if (!collection || !KNOWN.includes(collection as Known)) {
  return Astro.redirect('/admin')
}
const col = collection as Known
const isNew = id === 'new'

// Existing entry (when editing). getEntry resolves the slug as
// `<year>/<id>` for year-bucketed collections; we don't have the year
// here, so use the loader output instead.
type RawEntry = {
  id: string
  body?: string
  data: Record<string, unknown>
}
let entry: RawEntry | null = null
if (!isNew && id) {
  // Try direct id; if not found, search via getCollection. getEntry
  // wants the full slug (year/id) so we walk the collection instead.
  const { getCollection } = await import('astro:content')
  const all = (await getCollection(col as never)) as unknown as RawEntry[]
  entry = all.find((e) => (e.data?.id as string | undefined) === id || e.id === id) ?? null
  if (!entry) {
    return Astro.redirect(`/admin/${col}`)
  }
}

// Field defaults from the existing entry (when editing) or sensible
// blanks (when new).
const d = (entry?.data ?? {}) as Record<string, unknown>
const f = {
  id: String(d.id ?? ''),
  title: String(d.title ?? ''),
  date: String(d.date ?? ''),
  year: d.year ? Number(d.year) : new Date().getFullYear(),
  image: String(d.image ?? ''),
  file: String(d.file ?? ''),
  sideNoteTitle: String(d.sideNoteTitle ?? 'Details'),
  sideNote: String(d.sideNote ?? ''),
  detail: String(d.detail ?? ''),
  author: String(d.author ?? ''),
  source: String(d.source ?? ''),
  tags: Array.isArray(d.tags) ? (d.tags as string[]).join(', ') : '',
  marginsTags: Array.isArray(d.marginsTags) ? (d.marginsTags as string[]).join(', ') : '',
  sections: Array.isArray(d.sections) ? (d.sections as string[]) : ['writing'],
  body: entry?.body ?? '',
  forSale: d.forSale === true,
  prints: Array.isArray(d.prints)
    ? (d.prints as Array<{ size: string; priceCents: number }>)
    : [],
}
const PRINT_SIZES = ['8x10', '11x14', '16x20', '24x30'] as const

// Storage bucket per collection (drives the client uploader).
const BUCKETS: Record<Known, string | undefined> = {
  art: 'art-images',
  photo: 'photo-images',
  writing: 'pdf-files',
  margins: undefined,
  quotes: undefined,
  site: undefined,
}
const bucket = BUCKETS[col]

// Most-used tags across this collection — surfaced below the tag
// input so you can click a pill to add it rather than retyping. Top
// 18 keeps the row compact; rest you can still type by hand.
async function topTags(collection: Known, field: 'tags' | 'marginsTags'): Promise<string[]> {
  if (collection === 'quotes' || collection === 'site') return []
  const { getCollection } = await import('astro:content')
  const all = (await getCollection(collection as never)) as unknown as RawEntry[]
  const counts = new Map<string, number>()
  for (const e of all) {
    const raw = (e.data as Record<string, unknown>)[field]
    if (!Array.isArray(raw)) continue
    for (const t of raw) {
      const v = String(t).trim()
      if (!v) continue
      counts.set(v, (counts.get(v) ?? 0) + 1)
    }
  }
  return [...counts.entries()]
    .sort((a, b) => b[1] - a[1])
    .slice(0, 18)
    .map(([t]) => t)
}
const tagSuggestions = await topTags(col, col === 'margins' ? 'marginsTags' : 'tags')

const title = isNew ? `New ${col}` : (f.title || f.id || id)
---

<AdminLayout title={title} active={col}>
  <h1 class="admin-h1">{isNew ? `New ${col}` : title}</h1>
  <p class="admin-subtitle">
    <a href={`/admin/${col}`}>← Back to {col}</a>
  </p>

  <div id="save-status" class="admin-flash" style="display: none;"></div>

  <form
    id="admin-editor-form"
    data-collection={col}
    data-is-new={String(isNew)}
    data-media-bucket={bucket ?? ''}
  >
    {/* ── Common fields ─────────────────────────────────────────── */}
    {col !== 'quotes' && (
      <div class="admin-field">
        <label class="admin-label" for="title">Title</label>
        <input class="admin-input" type="text" id="title" name="title" value={f.title} required />
      </div>
    )}
    {col !== 'quotes' && col !== 'site' && (
      <>
        <div class="admin-field">
          <label class="admin-label" for="date">Date</label>
          <input class="admin-input" type="date" id="date" name="date" value={f.date} required />
        </div>
        <div class="admin-field">
          <label class="admin-label" for="year">Year</label>
          <input class="admin-input" type="number" id="year" name="year" value={String(f.year)} min="1900" max="2100" required />
          <span class="admin-hint">Auto-fills from Date.</span>
        </div>
      </>
    )}

    {/* Site entries have a fixed id and a single page — no need to
        surface the slug field to the editor. */}
    {col !== 'site' && (
      <div class="admin-field">
        <label class="admin-label" for="id">ID (also the filename)</label>
        <input class="admin-input" type="text" id="id" name="id" value={f.id} required readonly={!isNew} />
        <span class="admin-hint">{isNew ? 'Auto-filled from date or title. Edit if you want a custom slug.' : 'Renaming requires a delete + recreate; readonly when editing.'}</span>
      </div>
    )}
    {col === 'site' && (
      <input type="hidden" name="id" value={f.id || 'now'} />
    )}

    {/* ── Per-collection fields ─────────────────────────────────── */}

    {(col === 'art' || col === 'photo') && (
      <>
        <div class="admin-field">
          <label class="admin-label">Image</label>
          {bucket && (
            <input type="file" name="media-file" accept="image/*" class="admin-input" />
          )}
          <input type="hidden" name="image" value={f.image} />
          {f.image && (
            <img
              id="media-preview"
              src={f.image.startsWith('http') ? f.image : `/${f.image}`}
              alt="preview"
              class="admin-upload__preview"
              style="display: block;"
            />
          )}
          {!f.image && (
            <img id="media-preview" alt="preview" class="admin-upload__preview" style="display: none;" />
          )}
          <span class="admin-hint">Upload an image; the URL is filled in automatically.</span>
        </div>

        <div class="admin-field">
          <label class="admin-label" for="sideNoteTitle">Side note title</label>
          <input class="admin-input" type="text" id="sideNoteTitle" name="sideNoteTitle" value={f.sideNoteTitle} />
        </div>

        <div class="admin-field">
          <label class="admin-label" for="sideNote">Side note (HTML body)</label>
          <textarea class="admin-textarea" id="sideNote" name="sideNote" rows="6">{f.sideNote}</textarea>
          <span class="admin-hint">Free-form HTML. Renders on the right side of the entry page.</span>
          <details class="html-key">
            <summary>HTML cheatsheet</summary>
            <table class="html-key__table">
              <tr><th>What you want</th><th>How to write it</th></tr>
              <tr><td>Paragraph</td><td><code>&lt;p&gt;your text&lt;/p&gt;</code></td></tr>
              <tr><td>Line break (no blank line)</td><td><code>&lt;br /&gt;</code></td></tr>
              <tr><td>Italic</td><td><code>&lt;em&gt;italic&lt;/em&gt;</code></td></tr>
              <tr><td>Bold</td><td><code>&lt;strong&gt;bold&lt;/strong&gt;</code></td></tr>
              <tr><td>Link</td><td><code>&lt;a href="https://…"&gt;text&lt;/a&gt;</code></td></tr>
              <tr><td>Bullet list</td><td><code>&lt;ul&gt;&lt;li&gt;item&lt;/li&gt;&lt;li&gt;item&lt;/li&gt;&lt;/ul&gt;</code></td></tr>
              <tr><td>Numbered list</td><td><code>&lt;ol&gt;&lt;li&gt;item&lt;/li&gt;&lt;/ol&gt;</code></td></tr>
              <tr><td>Block quote</td><td><code>&lt;blockquote&gt;quoted text&lt;/blockquote&gt;</code></td></tr>
              <tr><td>Subheading</td><td><code>&lt;h3&gt;heading&lt;/h3&gt;</code></td></tr>
              <tr><td>Horizontal rule</td><td><code>&lt;hr /&gt;</code></td></tr>
            </table>
            <p class="html-key__note">
              Tip: every opening tag like <code>&lt;p&gt;</code> needs a matching close
              <code>&lt;/p&gt;</code>. Self-closing tags (<code>&lt;br /&gt;</code>, <code>&lt;hr /&gt;</code>)
              don't.
            </p>
          </details>
        </div>

        <div class="admin-field">
          <label class="admin-label" for="tags">Tags</label>
          <input class="admin-input tag-input" type="text" id="tags" name="tags" value={f.tags} />
          <span class="admin-hint">Comma-separated.</span>
          {tagSuggestions.length > 0 && (
            <div class="tag-suggest">
              <div class="tag-suggest__label">Click to add:</div>
              <div class="tag-suggest__row">
                {tagSuggestions.map((t) => (
                  <button type="button" class="tag-suggest__pill" data-tag-pill={t} data-target-input="tags">{t}</button>
                ))}
              </div>
            </div>
          )}
        </div>

        {/* ── Prints (commerce) ─────────────────────────────────────
           For-sale toggle gates the public "Buy a print" UI. The
           prints rows below it let you set per-size prices for THIS
           artwork — add a row per size you want to offer, leave
           sizes you don't want OUT. */}
        <div class="admin-field prints-block">
          <label class="admin-label">
            <input
              type="checkbox"
              name="forSale"
              value="true"
              checked={f.forSale}
              data-prints-toggle
            />
            For sale (offer prints of this artwork)
          </label>
          <div class="prints-editor" data-prints-editor hidden={!f.forSale}>
            <div class="prints-editor__head">
              <span class="prints-editor__col">Size</span>
              <span class="prints-editor__col">Price (USD)</span>
              <span></span>
            </div>
            <div class="prints-editor__rows" data-prints-rows>
              {f.prints.map((p) => (
                <div class="prints-editor__row" data-prints-row>
                  <select class="admin-input prints-editor__size" data-prints-size>
                    {PRINT_SIZES.map((s) => (
                      <option value={s} selected={s === p.size}>{s}</option>
                    ))}
                  </select>
                  <input
                    type="number"
                    class="admin-input prints-editor__price"
                    data-prints-price
                    min="1"
                    step="1"
                    value={(p.priceCents / 100).toString()}
                    placeholder="40"
                  />
                  <button type="button" class="prints-editor__remove" data-prints-remove aria-label="Remove">×</button>
                </div>
              ))}
            </div>
            <button type="button" class="admin-button admin-button--ghost prints-editor__add" data-prints-add>+ Add a size</button>
            <span class="admin-hint">
              Add one row per size you want to offer for this piece. Skip sizes
              you don't want offered. Prices are in whole dollars; tax is
              handled by Stripe at checkout.
            </span>
            <input type="hidden" name="prints" data-prints-hidden value={JSON.stringify(f.prints)} />
          </div>
        </div>
      </>
    )}

    {col === 'writing' && (
      <>
        <div class="admin-field">
          <label class="admin-label">PDF</label>
          {bucket && (
            <input type="file" name="media-file" accept="application/pdf" class="admin-input" />
          )}
          <input type="hidden" name="file" value={f.file} />
          {f.file && <p class="admin-hint">Current: <code>{f.file}</code></p>}
          <span class="admin-hint">Upload a PDF; the URL is filled in automatically.</span>
        </div>

        <div class="admin-field">
          <label class="admin-label">Sections (controls which page lists this essay)</label>
          <label style="display:block; margin: 4px 0;">
            <input type="checkbox" name="sections" value="writing" checked={f.sections.includes('writing')} />
            Writing (main essays list)
          </label>
          <label style="display:block; margin: 4px 0;">
            <input type="checkbox" name="sections" value="trips" checked={f.sections.includes('trips')} />
            Altered States (trip reports)
          </label>
        </div>

        <div class="admin-field">
          <label class="admin-label" for="tags">Tags</label>
          <input class="admin-input tag-input" type="text" id="tags" name="tags" value={f.tags} />
          <span class="admin-hint">Comma-separated.</span>
          {tagSuggestions.length > 0 && (
            <div class="tag-suggest">
              <div class="tag-suggest__label">Click to add:</div>
              <div class="tag-suggest__row">
                {tagSuggestions.map((t) => (
                  <button type="button" class="tag-suggest__pill" data-tag-pill={t} data-target-input="tags">{t}</button>
                ))}
              </div>
            </div>
          )}
        </div>
      </>
    )}

    {col === 'margins' && (
      <>
        <div class="admin-field">
          <label class="admin-label" for="body">Excerpt text</label>
          <textarea class="admin-textarea" id="body" name="body" rows="8" required>{f.body}</textarea>
        </div>

        <div class="admin-field">
          <label class="admin-label" for="detail">Source / attribution</label>
          <input class="admin-input" type="text" id="detail" name="detail" value={f.detail} />
          <span class="admin-hint">e.g. "Excerpt from: Harmonic Theism, Symphony No. I."</span>
        </div>

        <div class="admin-field">
          <label class="admin-label" for="marginsTags">Tags</label>
          <input class="admin-input tag-input" type="text" id="marginsTags" name="marginsTags" value={f.marginsTags} />
          <span class="admin-hint">Comma-separated.</span>
          {tagSuggestions.length > 0 && (
            <div class="tag-suggest">
              <div class="tag-suggest__label">Click to add:</div>
              <div class="tag-suggest__row">
                {tagSuggestions.map((t) => (
                  <button type="button" class="tag-suggest__pill" data-tag-pill={t} data-target-input="marginsTags">{t}</button>
                ))}
              </div>
            </div>
          )}
        </div>
      </>
    )}

    {col === 'quotes' && (
      <>
        <div class="admin-field">
          <label class="admin-label" for="body">Quote text</label>
          <textarea class="admin-textarea" id="body" name="body" rows="6" required>{f.body}</textarea>
        </div>

        <div class="admin-field">
          <label class="admin-label" for="author">Author</label>
          <input class="admin-input" type="text" id="author" name="author" value={f.author} />
        </div>

        <div class="admin-field">
          <label class="admin-label" for="source">Source / citation</label>
          <input class="admin-input" type="text" id="source" name="source" value={f.source} />
        </div>
      </>
    )}

    {col === 'site' && (
      <div class="admin-field">
        <label class="admin-label" for="body">Body</label>
        <textarea class="admin-textarea" id="body" name="body" rows="20" required>{f.body}</textarea>
        {(f.id === 'bio') ? (
          <details class="html-key" open>
            <summary>Biography page format</summary>
            <p class="html-key__note">
              Three sections, each headed by <code>##</code>:
            </p>
            <ul class="html-key__list">
              <li><strong><code>## profile</code></strong> — key/value rows for the archive panel. Each row starts with <code>- </code>, then the key, then <code>: </code>, then the value. Example: <code>- Type: Writer | Artist | Phenomenologist</code></li>
              <li><strong><code>## background</code></strong> — same key/value format. Renders as the bulleted "Background" cell. Two rows expected: <code>Previous</code> and <code>Current</code>.</li>
              <li><strong><code>## timeline</code></strong> — date-blocks separated by blank lines. First line of each block is the date label; remaining lines are the description. Lines starting with <code>- </code> become bullets.</li>
            </ul>
            <p class="html-key__note">
              In any line, you can use <code>[link text](/path)</code> for internal links or <code>[text](https://…)</code> for external. <code>**bold**</code> and <code>_italic_</code> also work inline.
            </p>
          </details>
        ) : (
          <span class="admin-hint">
            Markdown. Use <code>## Section</code> headings — each one becomes
            a card. List items under each section start with <code>- </code>.
            See <code>src/content/site/now.md</code> for the shape.
          </span>
        )}
      </div>
    )}

    <div class="admin-actions" style="margin-top: 24px;">
      <button type="submit" class="admin-button">{isNew ? 'Publish' : 'Save changes'}</button>
      <a class="admin-button admin-button--ghost" href={`/admin/${col}`}>Cancel</a>
      {!isNew && (
        <button type="button" id="admin-delete-btn" class="admin-button admin-button--danger" style="margin-left: auto;">Delete</button>
      )}
    </div>
  </form>

  <script>
    import '@/scripts/admin-editor.ts'
  </script>
</AdminLayout>
