---
// Static prerender — built at deploy time. Astro emits HTML; no
// serverless function. Admin routes opt OUT with prerender = false.
export const prerender = true

// ──────────────────────────────────────────────────────────────────────────────
// /writing/[id] — single essay viewer (PDF iframe). Pre-generated per
// non-trip writing entry. Trip reports get their own path at
// /altered-states/[id] (same shape; different sidebar active state).
//
// Markup mirrors legacy writings.html: a .writing-actions back-link +
// "Enter Fullscreen" link, then .essay-pdf > .pdf-container > iframe.
// ──────────────────────────────────────────────────────────────────────────────

import type { GetStaticPaths } from 'astro'
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { publicOnly } from '../../lib/sort-group'

export const getStaticPaths = (async () => {
  const writing = publicOnly(await getCollection('writing'))
  // Only non-trip writing — trip reports live on /altered-states/[id].
  const items = writing.filter(
    (it) => !(Array.isArray(it.data.sections) && it.data.sections.includes('trips')),
  )
  return items.map((item) => ({ params: { id: item.data.id }, props: { item } }))
}) satisfies GetStaticPaths

const { item } = Astro.props
const fromParam = Astro.url.searchParams.get('from') ?? 'writing'
const backHref = fromParam === 'archive' ? '/archive' : '/writing'
const backText = fromParam === 'archive' ? '← Back to Archive' : '← Back to Writing'

// PDF view tweaks — same fragment the legacy site appends so the embed
// opens at page-width fit instead of the browser default.
const pdfSrc = `/${item.data.file}#zoom=page-width&view=FitH`
const pdfOpen = `/${item.data.file}`
---

<BaseLayout title={item.data.title} active="writing">
  <header class="page-header">
    <h1>{item.data.title}</h1>
  </header>

  <div class="writing-actions">
    <a href={backHref}>{backText}</a>
    <a href={pdfOpen} target="_blank" rel="noopener">Enter Fullscreen</a>
  </div>

  <div class="essay-pdf">
    <div class="pdf-container">
      <iframe src={pdfSrc} title={item.data.title}></iframe>
    </div>
    <div class="pdf-mobile-link">
      <a href={pdfOpen} target="_blank" rel="noopener">Open PDF</a>
    </div>
  </div>
</BaseLayout>
