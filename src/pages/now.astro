---
// Static prerender — built at deploy time. Astro emits HTML; no
// serverless function. Admin routes opt OUT with prerender = false.
export const prerender = true

// ──────────────────────────────────────────────────────────────────────────────
// /now — currently painting / writing / reading.
//
// Content lives at src/content/site/now.md so the admin portal can edit it
// like any other entry. The markdown body uses `## Section` headings; this
// page parses them out and renders each as its own card. Update by either
// editing the .md file directly OR (after deploy) via the admin's /site/now
// editor.
// ──────────────────────────────────────────────────────────────────────────────

import { getEntry } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'

const entry = await getEntry('site', 'now')
const body = entry?.body ?? ''

// Parse `## Heading` sections. Each H2 starts a new card; everything
// between H2s is the card body. Lines starting with `- ` are list
// items; everything else passes through as a paragraph.
type Section = { title: string; items: string[]; paragraphs: string[] }

function parseSections(md: string): Section[] {
  const out: Section[] = []
  let current: Section | null = null
  const flushBuffer = (buf: string[]) => {
    if (!current) return
    const text = buf.join('\n').trim()
    if (text) current.paragraphs.push(text)
  }
  let para: string[] = []
  for (const rawLine of md.split('\n')) {
    const line = rawLine.replace(/\r$/, '')
    if (/^##\s+/.test(line)) {
      flushBuffer(para)
      para = []
      current = { title: line.replace(/^##\s+/, '').trim(), items: [], paragraphs: [] }
      out.push(current)
      continue
    }
    if (!current) continue
    // Accept any common bullet/dash marker, including the en-dash (–)
    // and em-dash (—) that iOS Smart Punctuation likes to substitute
    // for `- ` automatically. Without this, those lines render as
    // paragraphs in the heavier body style instead of light list
    // items, looking visually "bolder" than their siblings.
    if (/^[-–—•*]\s+/.test(line)) {
      flushBuffer(para)
      para = []
      current.items.push(line.replace(/^[-–—•*]\s+/, '').trim())
      continue
    }
    if (line.trim() === '') {
      flushBuffer(para)
      para = []
      continue
    }
    para.push(line)
  }
  flushBuffer(para)
  return out
}

const sections = parseSections(body)
---

<BaseLayout title="Now" active="now">
  <div class="now-page">
    <header class="page-header">
      <h1>Now</h1>
      <p class="page-intro">{entry?.data.title === 'Now' ? '' : entry?.data.title}</p>
    </header>

    <section class="now-grid">
      {sections.map((s) => (
        <article class="now-card">
          {/* Single label per card — the section heading from your
              markdown drives this directly. No "Currently" prefix is
              prepended; write it (or don't) in the markdown itself. */}
          <div class="now-kicker">{s.title}</div>
          {s.items.length > 0 && (
            <ul class="now-list">
              {s.items.map((it) => <li>{it}</li>)}
            </ul>
          )}
          {s.paragraphs.length > 0 && (
            <div class="now-prose">
              {s.paragraphs.map((p) => <p>{p}</p>)}
            </div>
          )}
        </article>
      ))}
    </section>
  </div>
</BaseLayout>
