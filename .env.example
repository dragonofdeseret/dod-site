# ──────────────────────────────────────────────────────────────────────────────
# Environment variables for local dev + Vercel deploy.
#
# Local: copy this file to `.env` and fill in real values.
# Vercel: set the same vars in Project Settings → Environment Variables.
#
# PUBLIC_ vars are baked into the client bundle (safe). Everything else
# stays server-side only.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — get these from Supabase Dashboard → Project Settings → API.
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# GitHub — fine-grained Personal Access Token with `contents: write` on
# the repo. Generate at https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=dragonofdeseret/christophershenefelt-site
# Optional. Defaults to "main".
# GITHUB_BRANCH=main

# Single admin email — only this address can sign in to /admin/. The
# Supabase magic-link login rejects everyone else server-side.
ADMIN_EMAIL=you@example.com
